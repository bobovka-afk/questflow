generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  moduleFormat  = "cjs"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
}

enum AuthTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum WorkspaceRole {
  ADMIN
  OWNER
  MEMBER
}

enum WorkspaceInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum ListColorPreset {
  GREEN
  YELLOW
  ORANGE
  RED
  PURPLE
  BLUE
  TEAL
  OLIVE
  BROWN
  GRAY
}

enum WorkspaceActivityType {
  WORKSPACE_CREATED
  WORKSPACE_UPDATED
  MEMBER_INVITED
  INVITE_CANCELLED
  INVITE_ACCEPTED
  INVITE_DECLINED
  MEMBER_REMOVED
  MEMBER_LEFT
}

enum GenderCharacter {
  MALE
  FEMALE
}

enum CharacterAvatarPreset {
  DRUID_MAN
  HUNTER_MAN
  MAGE_MAN
  PALADIN_MAN
  ROGUE_MAN
  WARRIOR_MAN
  DRUID_WOMAN
  HUNTER_WOMAN
  MAGE_WOMAN
  PALADIN_WOMAN
  ROGUE_WOMAN
  WARRIOR_WOMAN
  QUEST_MAGE_MAN
  QUEST_MAGE_WOMAN
}

enum XpEventType {
  TASK_COMPLETED
  DAILY_CHECKIN
  CHECKIN_STREAK
}

enum HealthEventReason {
  INACTIVITY_PENALTY
}

enum QuestPeriod {
  DAILY
  WEEKLY
}

enum QuestMetric {
  CARDS_COMPLETED
  CARDS_COMPLETED_WITH_DUE_TODAY
  COMMENTS_CREATED
  DAILY_CHECKIN_DONE
  ACTIVE_DAYS_WITH_XP
  DISTINCT_WORKSPACES_ACTIVE
}

enum ChestTier {
  COMMON
  RARE
  EPIC
}

enum CosmeticType {
  AVATAR_PRESET
  PORTRAIT_FRAME
  PROFILE_BACKGROUND
  TITLE_BADGE
}

enum AchievementMetric {
  CARDS_COMPLETED_TOTAL
  COMMENTS_TOTAL
  CHECKIN_STREAK_MAX
  CHARACTER_LEVEL
  QUESTS_COMPLETED_TOTAL
  CHESTS_OPENED_TOTAL
  DUST_EARNED_TOTAL
  COSMETICS_OWNED_COUNT
}

model User {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  passwordHash    String?   @map("password")
  name            String
  avatarPath      String?   @map("picture")
  emailVerifiedAt DateTime? @map("email_verified_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  authTokens           AuthToken[]
  workspaceMembers     WorkspaceMember[]
  workspaceInvitesSent WorkspaceInvite[]
  workspaceActivities  WorkspaceActivity[]
  assignedCards        Card[]
  comments             Comment[]
  character            Character?
  xpEvents             XpEvent[]
  healthEvents         HealthEvent[]
  questProgress        UserQuestProgress[]
  chests               UserChest[]
  inventory            InventoryItem[]
  questXpDays          UserQuestXpDay[]
  questWorkspaceDays   UserWorkspaceQuestDay[]
  achievements         UserAchievement[]
  achievementProgress  UserAchievementProgress[]
}

model AuthToken {
  id        Int           @id @default(autoincrement())
  userId    Int           @map("user_id")
  type      AuthTokenType
  tokenHash String        @unique @map("token_hash")
  expiresAt DateTime      @map("expires_at")
  createdAt DateTime      @default(now()) @map("created_at")
  usedAt    DateTime?     @map("used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workspace {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  members   WorkspaceMember[]
  invites   WorkspaceInvite[]
  boards    Board[]
  activities WorkspaceActivity[]
}

model WorkspaceMember {
  id          Int           @id @default(autoincrement())
  workspaceId Int           @map("workspace_id")
  userId      Int           @map("user_id")
  role        WorkspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model WorkspaceInvite {
  id              Int                   @id @default(autoincrement())
  email           String
  workspaceId     Int                   @map("workspace_id")
  invitedByUserId Int                   @map("invited_by_user_id")
  tokenHash       String?               @unique @map("token_hash")
  role            WorkspaceRole         @default(MEMBER)
  status          WorkspaceInviteStatus @default(PENDING)
  expiresAt       DateTime              @map("expires_at")
  createdAt       DateTime              @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation(fields: [invitedByUserId], references: [id], onDelete: Restrict)

  @@unique([workspaceId, email])
}

model WorkspaceActivity {
  id          Int                   @id @default(autoincrement())
  workspaceId Int                   @map("workspace_id")
  actorUserId Int                   @map("actor_user_id")
  type        WorkspaceActivityType
  payload     Json
  createdAt   DateTime              @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor     User      @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

}

model Board {
  id          Int       @id @default(autoincrement())
  workspaceId Int       @map("workspace_id")
  name        String
  description String?
  position    Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  list List[]
}

model List {
  id          Int             @id @default(autoincrement())
  boardId     Int             @map("board_id")
  name        String
  position    Int             @default(0)
  colorPreset ListColorPreset @default(GRAY) @map("color_preset")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  cards Card[]
}

model Card {
  id          Int       @id @default(autoincrement())
  listId      Int       @map("list_id")
  title       String
  description String?
  dueDate     DateTime? @map("due_date")
  position    Int       @default(0)
  assigneeId  Int?      @map("assignee_id")
  isCompleted Boolean   @default(false) @map("is_completed")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  list     List      @relation(fields: [listId], references: [id], onDelete: Cascade)
  assignee User?     @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  comments Comment[]
  xpEvents XpEvent[]
}

model Comment {
  id        Int      @id @default(autoincrement())
  cardId    Int      @map("card_id")
  userId    Int      @map("user_id")
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

}

model Character {
  id           Int                     @id @default(autoincrement())
  userId       Int                     @unique @map("user_id")
  name         String
  gender       GenderCharacter
  avatarPreset CharacterAvatarPreset   @map("avatar_preset")

  currentXp Int @default(0) @map("current_xp")
  level   Int @default(1)
  health Int @default(100)
  dailyTaskXpCount Int @default(0) @map("daily_task_xp_count")
  checkinStreak Int @default(0) @map("checkin_streak")
  lastCheckinDayKey DateTime? @map("last_checkin_day_key") @db.Date

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  equippedPortraitFrameKey     String? @map("equipped_portrait_frame_key")
  equippedProfileBackgroundKey String? @map("equipped_profile_background_key")
  equippedTitleBadgeKey        String? @map("equipped_title_badge_key")
  dust                         Int     @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model QuestTemplate {
  id              Int         @id @default(autoincrement())
  key             String      @unique
  period          QuestPeriod
  metric          QuestMetric
  target          Int
  rewardChestTier ChestTier   @map("reward_chest_tier")
  titleRu         String      @map("title_ru")
  descriptionRu   String?     @map("description_ru")
  sortOrder       Int         @default(0) @map("sort_order")
  active          Boolean     @default(true)

  progress UserQuestProgress[]
}

model UserQuestProgress {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  templateId  Int       @map("template_id")
  periodKey   String    @map("period_key")
  current     Int       @default(0)
  completedAt DateTime? @map("completed_at")
  chestId     Int?      @unique @map("chest_id")

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  template QuestTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  chest    UserChest?    @relation(fields: [chestId], references: [id], onDelete: SetNull)

  @@unique([userId, templateId, periodKey])
}

model UserChest {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  tier      ChestTier
  source    String
  openedAt  DateTime? @map("opened_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  progress UserQuestProgress?

  @@unique([userId, source])
}

model CosmeticItem {
  id   Int          @id @default(autoincrement())
  type CosmeticType
  key  String       @unique
  tier ChestTier
  nameRu String @map("name_ru")

  inventory InventoryItem[]
}

model InventoryItem {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  cosmeticItemId Int      @map("cosmetic_item_id")
  equipped       Boolean  @default(false)
  obtainedAt     DateTime @default(now()) @map("obtained_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  cosmeticItem CosmeticItem @relation(fields: [cosmeticItemId], references: [id], onDelete: Cascade)

  @@unique([userId, cosmeticItemId])
}

model UserQuestXpDay {
  userId  Int      @map("user_id")
  dayKey  DateTime @map("day_key") @db.Date

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, dayKey])
}

model UserWorkspaceQuestDay {
  userId      Int      @map("user_id")
  workspaceId Int      @map("workspace_id")
  dayKey      DateTime @map("day_key") @db.Date

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, workspaceId, dayKey])
}

model AchievementTemplate {
  id            Int               @id @default(autoincrement())
  key           String            @unique
  metric        AchievementMetric
  target        Int
  titleRu       String            @map("title_ru")
  descriptionRu String?           @map("description_ru")
  rewardDust    Int               @default(0) @map("reward_dust")
  sortOrder     Int               @default(0) @map("sort_order")
  active        Boolean           @default(true)

  unlocks UserAchievement[]
}

model UserAchievement {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  templateId Int      @map("template_id")
  unlockedAt DateTime @default(now()) @map("unlocked_at")

  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  template AchievementTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([userId, templateId])
}

model UserAchievementProgress {
  userId  Int               @map("user_id")
  metric  AchievementMetric
  current Int               @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, metric])
}

model XpEvent {
  id        Int         @id @default(autoincrement())
  userId    Int         @map("user_id")
  type      XpEventType
  cardId    Int?        @map("card_id")
  dayKey    DateTime?   @map("day_key") @db.Date
  xpAmount  Int         @map("xp_amount")
  createdAt DateTime    @default(now()) @map("created_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card? @relation(fields: [cardId], references: [id], onDelete: SetNull)

  @@unique([userId, type, cardId])
  @@unique([userId, type, dayKey])
}

model HealthEvent {
  id        Int               @id @default(autoincrement())
  userId    Int               @map("user_id")
  dayKey    DateTime          @map("day_key") @db.Date
  delta     Int
  reason    HealthEventReason
  createdAt DateTime          @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayKey, reason])
}
