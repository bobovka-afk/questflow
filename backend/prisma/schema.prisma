generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  moduleFormat  = "cjs"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
}

enum AuthTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  EMAIL_CHANGE_OLD
  EMAIL_CHANGE_NEW
}

enum UserSecurityEventType {
  PASSWORD_CHANGED
  PASSWORD_SET
  PASSWORD_RESET
  SESSION_CREATED
  SESSION_REVOKED
  SESSIONS_REVOKED_ALL_OTHER
  GAMIFICATION_SETTINGS_CHANGED
  SITE_SETTINGS_CHANGED
  SECURITY_SETTINGS_CHANGED
  EMAIL_CHANGE_REQUESTED
  EMAIL_CHANGED
  ACCOUNT_DELETED
}

enum WorkspaceRole {
  ADMIN
  OWNER
  MEMBER
}

enum WorkspaceInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum ListColorPreset {
  GREEN
  YELLOW
  ORANGE
  RED
  PURPLE
  BLUE
  TEAL
  OLIVE
  BROWN
  GRAY
}

enum CardCoverDisplayMode {
  NONE
  BANNER
  FULL
}

enum WorkspaceActivityType {
  WORKSPACE_CREATED
  WORKSPACE_UPDATED
  MEMBER_INVITED
  INVITE_CANCELLED
  INVITE_ACCEPTED
  INVITE_DECLINED
  MEMBER_REMOVED
  MEMBER_LEFT
}

enum UserNotificationType {
  MENTION
  DEADLINE
  XP_GAIN
  QUEST_COMPLETED
  CHEST_READY
  ACHIEVEMENT
  PARTY_RAID_INVITE
  FRIEND_REQUEST
  CARD_ASSIGNED
}

enum GenderCharacter {
  MALE
  FEMALE
}

enum CharacterAvatarPreset {
  DRUID_MAN
  HUNTER_MAN
  MAGE_MAN
  PALADIN_MAN
  ROGUE_MAN
  WARRIOR_MAN
  DRUID_WOMAN
  HUNTER_WOMAN
  MAGE_WOMAN
  PALADIN_WOMAN
  ROGUE_WOMAN
  WARRIOR_WOMAN
  QUEST_MAGE_MAN
  QUEST_MAGE_WOMAN
}

enum XpEventType {
  TASK_COMPLETED
  DAILY_CHECKIN
  CHECKIN_STREAK
  PERSONAL_TODO_COMPLETED
  PERSONAL_DAILY_COMPLETED
  HABIT_POSITIVE
}

enum HealthEventReason {
  INACTIVITY_PENALTY
  HABIT_NEGATIVE
  MISSED_DAILY
}

enum QuestPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

enum QuestMetric {
  CARDS_COMPLETED
  CARDS_COMPLETED_WITH_DUE_TODAY
  COMMENTS_CREATED
  DAILY_CHECKIN_DONE
  ACTIVE_DAYS_WITH_XP
  DISTINCT_WORKSPACES_ACTIVE
  PERSONAL_ACTIONS_COMPLETED
  HABIT_POSITIVE_LOGGED
  PERSONAL_DAILIES_ALL_DONE
}

enum ChestTier {
  COMMON
  RARE
  EPIC
}

enum CosmeticType {
  AVATAR_PRESET
  PORTRAIT_FRAME
  PROFILE_BACKGROUND
  TITLE_BADGE
}

enum AchievementMetric {
  CARDS_COMPLETED_TOTAL
  CHECKIN_STREAK_MAX
  CHARACTER_LEVEL
  QUESTS_COMPLETED_TOTAL
  DUST_EARNED_TOTAL
  COSMETICS_OWNED_COUNT
  PERSONAL_TODOS_COMPLETED_TOTAL
  HABIT_POSITIVE_LOGGED_TOTAL
  HABIT_STREAK_BEST_MAX
  PERSONAL_DAILIES_ALL_DONE_TOTAL
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum PartyRaidStatus {
  INVITING
  ACTIVE
  DEFEATED
  EXPIRED
  CANCELLED
}

enum PartyMemberStatus {
  INVITED
  ACTIVE
  KICKED
  LEFT
  DECLINED
}

enum HabitPolarity {
  POSITIVE
  NEGATIVE
  BOTH
}

enum DailySchedule {
  EVERY_DAY
}

enum PartyMemberRole {
  LEADER
  MEMBER
}

enum PartyKickVoteStatus {
  OPEN
  PASSED
  REJECTED
}

model User {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  passwordHash    String?   @map("password")
  name            String
  username        String?   @unique
  avatarPath      String?   @map("picture")
  emailVerifiedAt DateTime? @map("email_verified_at")
  lastActiveAt    DateTime  @default(now()) @map("last_active_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  authTokens           AuthToken[]
  blocksInitiated      UserBlock[]            @relation("UserBlocksInitiated")
  blocksReceived       UserBlock[]            @relation("UserBlocksReceived")
  pushSubscriptions    WebPushSubscription[]
  workspaceMembers     WorkspaceMember[]
  workspaceInvitesSent WorkspaceInvite[]
  workspaceActivities  WorkspaceActivity[]
  assignedCards        Card[]
  cardAttachments      CardAttachment[]
  comments             Comment[]
  character            Character?
  xpEvents             XpEvent[]
  healthEvents         HealthEvent[]
  questProgress        UserQuestProgress[]
  chests               UserChest[]
  inventory            InventoryItem[]
  questXpDays          UserQuestXpDay[]
  questWorkspaceDays   UserWorkspaceQuestDay[]
  achievements         UserAchievement[]
  achievementProgress  UserAchievementProgress[]
  settings             UserSettings?
  sessions             UserSession[]
  securityEvents       UserSecurityEvent[]
  friendRequestsSent     FriendRequest[] @relation("FriendRequestRequester")
  friendRequestsReceived FriendRequest[] @relation("FriendRequestAddressee")
  directMessagesSent     DirectMessage[] @relation("DirectMessageSender")
  directMessagesReceived DirectMessage[] @relation("DirectMessageRecipient")
  partyRaidsLed          PartyRaid[] @relation("PartyRaidLeader")
  partyRaidMembers       PartyRaidMember[]
  partyRaidHits          PartyRaidHit[]
  partyKickVotesInitiated PartyKickVote[] @relation("PartyKickVoteInitiator")
  partyKickBallots       PartyKickBallot[]
  notifications          UserNotification[]
  personalHabits         PersonalHabit[]
  personalDailies        PersonalDaily[]
  personalTodos          PersonalTodo[]
  personalDailyMisses    PersonalDailyMissLog[]
  personalHabitNegatives PersonalHabitNegativeLog[]
}

model AuthToken {
  id        Int           @id @default(autoincrement())
  userId    Int           @map("user_id")
  type      AuthTokenType
  tokenHash String        @unique @map("token_hash")
  expiresAt DateTime      @map("expires_at")
  createdAt DateTime      @default(now()) @map("created_at")
  usedAt    DateTime?     @map("used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workspace {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  members   WorkspaceMember[]
  invites   WorkspaceInvite[]
  boards    Board[]
  activities WorkspaceActivity[]
  labels    WorkspaceLabel[]
}

model WorkspaceMember {
  id          Int           @id @default(autoincrement())
  workspaceId Int           @map("workspace_id")
  userId      Int           @map("user_id")
  role        WorkspaceRole @default(MEMBER)
  permissions Json?
  sortOrder   Int           @default(0) @map("sort_order")
  createdAt   DateTime      @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model WorkspaceInvite {
  id              Int                   @id @default(autoincrement())
  email           String
  workspaceId     Int                   @map("workspace_id")
  invitedByUserId Int                   @map("invited_by_user_id")
  tokenHash       String?               @unique @map("token_hash")
  role            WorkspaceRole         @default(MEMBER)
  status          WorkspaceInviteStatus @default(PENDING)
  expiresAt       DateTime              @map("expires_at")
  createdAt       DateTime              @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation(fields: [invitedByUserId], references: [id], onDelete: Restrict)

  @@unique([workspaceId, email])
}

model WorkspaceActivity {
  id          Int                   @id @default(autoincrement())
  workspaceId Int                   @map("workspace_id")
  actorUserId Int                   @map("actor_user_id")
  type        WorkspaceActivityType
  payload     Json
  createdAt   DateTime              @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor     User      @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

}

model Board {
  id          Int       @id @default(autoincrement())
  workspaceId Int       @map("workspace_id")
  name        String
  description String?
  position    Int       @default(0)
  archivedAt  DateTime? @map("archived_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  list List[]
}

model List {
  id          Int             @id @default(autoincrement())
  boardId     Int             @map("board_id")
  name        String
  position    Int             @default(0)
  colorPreset ListColorPreset @default(GRAY) @map("color_preset")
  archivedAt  DateTime?       @map("archived_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  cards Card[]
}

enum CardAttachmentKind {
  FILE
  LINK
}

model Card {
  id                    Int       @id @default(autoincrement())
  listId                Int       @map("list_id")
  title                 String
  description           String?
  dueDate               DateTime? @map("due_date")
  reminderMinutesBefore Int?      @map("reminder_minutes_before")
  reminderNotifiedAt    DateTime? @map("reminder_notified_at")
  position              Int       @default(0)
  assigneeId            Int?      @map("assignee_id")
  isCompleted           Boolean              @default(false) @map("is_completed")
  coverAttachmentId     Int?                 @unique @map("cover_attachment_id")
  coverColorPreset      ListColorPreset?     @map("cover_color_preset")
  coverDisplayMode      CardCoverDisplayMode @default(NONE) @map("cover_display_mode")
  archivedAt            DateTime?            @map("archived_at")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")

  list            List             @relation(fields: [listId], references: [id], onDelete: Cascade)
  assignee        User?            @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  comments        Comment[]
  xpEvents        XpEvent[]
  labels          CardLabel[]
  attachments     CardAttachment[]
  coverAttachment CardAttachment?  @relation("CardCover", fields: [coverAttachmentId], references: [id], onDelete: SetNull)
}

model CardAttachment {
  id           Int                @id @default(autoincrement())
  cardId       Int                @map("card_id")
  uploaderId   Int                @map("uploader_id")
  kind         CardAttachmentKind
  fileName     String             @map("file_name")
  mimeType     String?            @map("mime_type")
  sizeBytes    Int?               @map("size_bytes")
  storagePath  String?            @map("storage_path")
  previewPath  String?            @map("preview_path")
  externalUrl  String?            @map("external_url")
  createdAt    DateTime           @default(now()) @map("created_at")

  card         Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  uploader     User  @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  coverForCard Card? @relation("CardCover")

  @@index([cardId])
}

model WorkspaceLabel {
  id          Int             @id @default(autoincrement())
  workspaceId Int             @map("workspace_id")
  name        String
  colorPreset ListColorPreset @default(GREEN) @map("color_preset")
  createdAt   DateTime        @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  cards     CardLabel[]

  @@unique([workspaceId, name])
}

model CardLabel {
  cardId  Int @map("card_id")
  labelId Int @map("label_id")

  card  Card           @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label WorkspaceLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([cardId, labelId])
}

model UserBlock {
  id        Int      @id @default(autoincrement())
  blockerId Int      @map("blocker_id")
  blockedId Int      @map("blocked_id")
  createdAt DateTime @default(now()) @map("created_at")

  blocker User @relation("UserBlocksInitiated", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("UserBlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

model WebPushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserNotification {
  id        Int                  @id @default(autoincrement())
  userId    Int                  @map("user_id")
  type      UserNotificationType
  payload   Json
  readAt    DateTime?            @map("read_at")
  createdAt DateTime             @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model Comment {
  id        Int      @id @default(autoincrement())
  cardId    Int      @map("card_id")
  userId    Int      @map("user_id")
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

}

model Character {
  id           Int                     @id @default(autoincrement())
  userId       Int                     @unique @map("user_id")
  name         String
  gender       GenderCharacter
  avatarPreset CharacterAvatarPreset   @map("avatar_preset")

  currentXp Int @default(0) @map("current_xp")
  level   Int @default(1)
  health Int @default(100)
  manaCurrent Int @default(0) @map("mana_current")
  dailyActivityXpEarned Int @default(0) @map("daily_activity_xp_earned")
  checkinStreak Int @default(0) @map("checkin_streak")
  lastCheckinDayKey DateTime? @map("last_checkin_day_key") @db.Date

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  equippedPortraitFrameKey     String? @map("equipped_portrait_frame_key")
  equippedProfileBackgroundKey String? @map("equipped_profile_background_key")
  equippedTitleBadgeKey        String? @map("equipped_title_badge_key")
  dust                         Int     @default(0)
  friendCode                   Int     @unique @map("friend_code")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FriendRequest {
  id          Int                 @id @default(autoincrement())
  requesterId Int                 @map("requester_id")
  addresseeId Int                 @map("addressee_id")
  status      FriendRequestStatus @default(PENDING)
  createdAt   DateTime            @default(now()) @map("created_at")
  respondedAt DateTime?           @map("responded_at")

  requester User @relation("FriendRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendRequestAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
}

model DirectMessage {
  id          Int       @id @default(autoincrement())
  senderId    Int       @map("sender_id")
  recipientId Int       @map("recipient_id")
  body        String    @db.VarChar(2000)
  readAt      DateTime? @map("read_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  sender    User @relation("DirectMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User @relation("DirectMessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, readAt])
  @@index([recipientId, createdAt])
  @@index([senderId, recipientId, createdAt])
}

model PartyRaid {
  id            Int             @id @default(autoincrement())
  bossKey       String          @map("boss_key")
  leaderId      Int             @map("leader_id")
  status        PartyRaidStatus @default(INVITING)
  remainingPct  Float           @default(100) @map("remaining_pct")
  startedAt     DateTime?       @map("started_at")
  expiresAt     DateTime?       @map("expires_at")
  defeatedAt    DateTime?       @map("defeated_at")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  leader    User              @relation("PartyRaidLeader", fields: [leaderId], references: [id], onDelete: Cascade)
  members   PartyRaidMember[]
  hits      PartyRaidHit[]
  kickVotes PartyKickVote[]

  @@index([leaderId, status])
  @@index([status, expiresAt])
}

model PartyRaidMember {
  id              Int               @id @default(autoincrement())
  raidId          Int               @map("raid_id")
  userId          Int               @map("user_id")
  role            PartyMemberRole
  status          PartyMemberStatus @default(INVITED)
  contributionPct Float             @default(0) @map("contribution_pct")
  joinedAt        DateTime?         @map("joined_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  raid PartyRaid @relation(fields: [raidId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([raidId, userId])
  @@index([userId, status])
}

model PartyRaidHit {
  id        Int      @id @default(autoincrement())
  raidId    Int      @map("raid_id")
  userId    Int      @map("user_id")
  damagePct Float    @map("damage_pct")
  createdAt DateTime @default(now()) @map("created_at")

  raid PartyRaid @relation(fields: [raidId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([raidId, createdAt])
}

model PartyKickVote {
  id            Int                 @id @default(autoincrement())
  raidId        Int                 @map("raid_id")
  targetUserId  Int                 @map("target_user_id")
  initiatorId   Int                 @map("initiator_id")
  status        PartyKickVoteStatus @default(OPEN)
  createdAt     DateTime            @default(now()) @map("created_at")
  resolvedAt    DateTime?           @map("resolved_at")

  raid      PartyRaid           @relation(fields: [raidId], references: [id], onDelete: Cascade)
  initiator User                @relation("PartyKickVoteInitiator", fields: [initiatorId], references: [id], onDelete: Cascade)
  ballots   PartyKickBallot[]

  @@index([raidId, status])
}

model PartyKickBallot {
  id        Int      @id @default(autoincrement())
  voteId    Int      @map("vote_id")
  voterId   Int      @map("voter_id")
  createdAt DateTime @default(now()) @map("created_at")

  vote  PartyKickVote @relation(fields: [voteId], references: [id], onDelete: Cascade)
  voter User          @relation(fields: [voterId], references: [id], onDelete: Cascade)

  @@unique([voteId, voterId])
}

model QuestTemplate {
  id              Int         @id @default(autoincrement())
  key             String      @unique
  period          QuestPeriod
  metric          QuestMetric
  target          Int
  rewardChestTier ChestTier   @map("reward_chest_tier")
  titleRu         String      @map("title_ru")
  descriptionRu   String?     @map("description_ru")
  sortOrder       Int         @default(0) @map("sort_order")
  active          Boolean     @default(true)

  progress UserQuestProgress[]
}

model UserQuestProgress {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  templateId  Int       @map("template_id")
  periodKey   String    @map("period_key")
  current     Int       @default(0)
  completedAt DateTime? @map("completed_at")
  chestId     Int?      @unique @map("chest_id")

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  template QuestTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  chest    UserChest?    @relation(fields: [chestId], references: [id], onDelete: SetNull)

  @@unique([userId, templateId, periodKey])
}

model UserChest {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  tier      ChestTier
  source    String
  openedAt  DateTime? @map("opened_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  progress UserQuestProgress?

  @@unique([userId, source])
}

model CosmeticItem {
  id   Int          @id @default(autoincrement())
  type CosmeticType
  key  String       @unique
  tier ChestTier
  nameRu String @map("name_ru")

  inventory InventoryItem[]
}

model InventoryItem {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  cosmeticItemId Int      @map("cosmetic_item_id")
  equipped       Boolean  @default(false)
  obtainedAt     DateTime @default(now()) @map("obtained_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  cosmeticItem CosmeticItem @relation(fields: [cosmeticItemId], references: [id], onDelete: Cascade)

  @@unique([userId, cosmeticItemId])
}

model UserQuestXpDay {
  userId  Int      @map("user_id")
  dayKey  DateTime @map("day_key") @db.Date

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, dayKey])
}

model UserWorkspaceQuestDay {
  userId      Int      @map("user_id")
  workspaceId Int      @map("workspace_id")
  dayKey      DateTime @map("day_key") @db.Date

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, workspaceId, dayKey])
}

model AchievementTemplate {
  id            Int               @id @default(autoincrement())
  key           String            @unique
  metric        AchievementMetric
  target        Int
  titleRu       String            @map("title_ru")
  descriptionRu String?           @map("description_ru")
  rewardDust    Int               @default(0) @map("reward_dust")
  sortOrder     Int               @default(0) @map("sort_order")
  active        Boolean           @default(true)

  unlocks UserAchievement[]
}

model UserAchievement {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  templateId Int      @map("template_id")
  unlockedAt DateTime @default(now()) @map("unlocked_at")

  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  template AchievementTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([userId, templateId])
}

model UserAchievementProgress {
  userId  Int               @map("user_id")
  metric  AchievementMetric
  current Int               @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, metric])
}

model XpEvent {
  id        Int         @id @default(autoincrement())
  userId    Int         @map("user_id")
  type      XpEventType
  cardId    Int?        @map("card_id")
  personalTodoId   Int? @map("personal_todo_id")
  personalDailyId  Int? @map("personal_daily_id")
  personalHabitId  Int? @map("personal_habit_id")
  dayKey    DateTime?   @map("day_key") @db.Date
  xpAmount  Int         @map("xp_amount")
  createdAt DateTime    @default(now()) @map("created_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card? @relation(fields: [cardId], references: [id], onDelete: SetNull)
  personalTodo  PersonalTodo?  @relation(fields: [personalTodoId], references: [id], onDelete: SetNull)
  personalDaily PersonalDaily? @relation(fields: [personalDailyId], references: [id], onDelete: SetNull)
  personalHabit PersonalHabit? @relation(fields: [personalHabitId], references: [id], onDelete: SetNull)

  @@unique([userId, type, cardId])
  @@unique([userId, type, dayKey])
  @@unique([userId, type, personalTodoId])
  @@unique([userId, type, personalDailyId, dayKey])
  @@unique([userId, type, personalHabitId, dayKey])
}

model HealthEvent {
  id        Int               @id @default(autoincrement())
  userId    Int               @map("user_id")
  dayKey    DateTime          @map("day_key") @db.Date
  delta     Int
  reason    HealthEventReason
  createdAt DateTime          @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayKey, reason])
}

model UserSettings {
  userId       Int      @id @map("user_id")
  gamification Json     @default("{}")
  site         Json     @default("{}")
  security     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSession {
  id               String    @id @default(uuid())
  userId           Int       @map("user_id")
  refreshTokenHash String    @unique @map("refresh_token_hash")
  userAgent        String?   @map("user_agent")
  ipAddress        String?   @map("ip_address")
  deviceLabel      String?   @map("device_label")
  lastSeenAt       DateTime  @default(now()) @map("last_seen_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")

  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  securityEvents UserSecurityEvent[]

  @@index([userId])
  @@index([userId, revokedAt])
}

model UserSecurityEvent {
  id        Int                   @id @default(autoincrement())
  userId    Int                   @map("user_id")
  type      UserSecurityEventType
  metadata  Json?
  ipAddress String?               @map("ip_address")
  userAgent String?               @map("user_agent")
  sessionId String?               @map("session_id")
  createdAt DateTime              @default(now()) @map("created_at")

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  session UserSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
}

model PersonalHabit {
  id            Int           @id @default(autoincrement())
  userId        Int           @map("user_id")
  title         String
  polarity      HabitPolarity @default(BOTH)
  emoji         String?
  color         String?
  sortOrder     Int           @default(0) @map("sort_order")
  streakCurrent Int           @default(0) @map("streak_current")
  streakBest    Int           @default(0) @map("streak_best")
  positiveCount Int           @default(0) @map("positive_count")
  negativeCount Int           @default(0) @map("negative_count")
  archivedAt    DateTime?     @map("archived_at")
  createdAt     DateTime      @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  xpEvents XpEvent[]
  negativeLogs PersonalHabitNegativeLog[]

  @@index([userId, archivedAt])
}

model PersonalDaily {
  id                  Int           @id @default(autoincrement())
  userId              Int           @map("user_id")
  title               String
  schedule            DailySchedule @default(EVERY_DAY)
  sortOrder           Int           @default(0) @map("sort_order")
  streakCurrent       Int           @default(0) @map("streak_current")
  streakBest          Int           @default(0) @map("streak_best")
  lastCompletedDayKey DateTime?     @map("last_completed_day_key") @db.Date
  archivedAt          DateTime?     @map("archived_at")
  createdAt           DateTime      @default(now()) @map("created_at")

  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  xpEvents  XpEvent[]
  missLogs  PersonalDailyMissLog[]

  @@index([userId, archivedAt])
}

model PersonalTodo {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  title       String
  notes       String?
  dueAt       DateTime? @map("due_at")
  isCompleted Boolean   @default(false) @map("is_completed")
  completedAt DateTime? @map("completed_at")
  sortOrder   Int       @default(0) @map("sort_order")
  archivedAt  DateTime? @map("archived_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  xpEvents XpEvent[]

  @@index([userId, isCompleted, archivedAt])
}

model PersonalDailyMissLog {
  id              Int      @id @default(autoincrement())
  userId          Int      @map("user_id")
  personalDailyId Int      @map("personal_daily_id")
  dayKey          DateTime @map("day_key") @db.Date
  hpDelta         Int      @map("hp_delta")
  createdAt       DateTime @default(now()) @map("created_at")

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  personalDaily PersonalDaily @relation(fields: [personalDailyId], references: [id], onDelete: Cascade)

  @@unique([userId, personalDailyId, dayKey])
  @@index([userId, dayKey])
}

model PersonalHabitNegativeLog {
  id              Int      @id @default(autoincrement())
  userId          Int      @map("user_id")
  personalHabitId Int      @map("personal_habit_id")
  dayKey          DateTime @map("day_key") @db.Date
  hpDelta         Int      @map("hp_delta")
  createdAt       DateTime @default(now()) @map("created_at")

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  personalHabit PersonalHabit @relation(fields: [personalHabitId], references: [id], onDelete: Cascade)

  @@unique([userId, personalHabitId, dayKey])
  @@index([userId, dayKey])
}
