generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  moduleFormat  = "cjs"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
}

enum AuthTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum WorkspaceRole {
  ADMIN
  OWNER
  MEMBER
}

enum WorkspaceInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum ListColorPreset {
  GREEN
  YELLOW
  ORANGE
  RED
  PURPLE
  BLUE
  TEAL
  OLIVE
  BROWN
  GRAY
}

enum WorkspaceActivityType {
  WORKSPACE_CREATED
  WORKSPACE_UPDATED
  MEMBER_INVITED
  INVITE_CANCELLED
  INVITE_ACCEPTED
  INVITE_DECLINED
  MEMBER_REMOVED
  MEMBER_LEFT
}

enum GenderCharacter {
  MALE
  FEMALE
}

enum CharacterAvatarPreset {
  DRUID_MAN
  HUNTER_MAN
  MAGE_MAN
  PALADIN_MAN
  ROGUE_MAN
  WARRIOR_MAN
  DRUID_WOMAN
  HUNTER_WOMAN
  MAGE_WOMAN
  PALADIN_WOMAN
  ROGUE_WOMAN
  WARRIOR_WOMAN
}

enum XpEventType {
  TASK_COMPLETED
  DAILY_CHECKIN
  CHECKIN_STREAK
}

enum HealthEventReason {
  INACTIVITY_PENALTY
}

model User {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  passwordHash    String?   @map("password")
  name            String
  avatarPath      String?   @map("picture")
  emailVerifiedAt DateTime? @map("email_verified_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  authTokens           AuthToken[]
  workspaceMembers     WorkspaceMember[]
  workspaceInvitesSent WorkspaceInvite[]
  workspaceActivities  WorkspaceActivity[]
  assignedCards        Card[]
  comments             Comment[]
  character            Character?
  xpEvents             XpEvent[]
  healthEvents         HealthEvent[]
}

model AuthToken {
  id        Int           @id @default(autoincrement())
  userId    Int           @map("user_id")
  type      AuthTokenType
  tokenHash String        @unique @map("token_hash")
  expiresAt DateTime      @map("expires_at")
  createdAt DateTime      @default(now()) @map("created_at")
  usedAt    DateTime?     @map("used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workspace {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  members   WorkspaceMember[]
  invites   WorkspaceInvite[]
  boards    Board[]
  activities WorkspaceActivity[]
}

model WorkspaceMember {
  id          Int           @id @default(autoincrement())
  workspaceId Int           @map("workspace_id")
  userId      Int           @map("user_id")
  role        WorkspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model WorkspaceInvite {
  id              Int                   @id @default(autoincrement())
  email           String
  workspaceId     Int                   @map("workspace_id")
  invitedByUserId Int                   @map("invited_by_user_id")
  tokenHash       String?               @unique @map("token_hash")
  role            WorkspaceRole         @default(MEMBER)
  status          WorkspaceInviteStatus @default(PENDING)
  expiresAt       DateTime              @map("expires_at")
  createdAt       DateTime              @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation(fields: [invitedByUserId], references: [id], onDelete: Restrict)

  @@unique([workspaceId, email])
}

model WorkspaceActivity {
  id          Int                   @id @default(autoincrement())
  workspaceId Int                   @map("workspace_id")
  actorUserId Int                   @map("actor_user_id")
  type        WorkspaceActivityType
  payload     Json
  createdAt   DateTime              @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor     User      @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

}

model Board {
  id          Int       @id @default(autoincrement())
  workspaceId Int       @map("workspace_id")
  name        String
  description String?
  position    Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  list List[]
}

model List {
  id          Int             @id @default(autoincrement())
  boardId     Int             @map("board_id")
  name        String
  position    Int             @default(0)
  colorPreset ListColorPreset @default(GRAY) @map("color_preset")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  cards Card[]
}

model Card {
  id          Int       @id @default(autoincrement())
  listId      Int       @map("list_id")
  title       String
  description String?
  dueDate     DateTime? @map("due_date")
  position    Int       @default(0)
  assigneeId  Int?      @map("assignee_id")
  isCompleted Boolean   @default(false) @map("is_completed")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  list     List      @relation(fields: [listId], references: [id], onDelete: Cascade)
  assignee User?     @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  comments Comment[]
  xpEvents XpEvent[]
}

model Comment {
  id        Int      @id @default(autoincrement())
  cardId    Int      @map("card_id")
  userId    Int      @map("user_id")
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

}

model Character {
  id           Int                     @id @default(autoincrement())
  userId       Int                     @unique @map("user_id")
  name         String
  gender       GenderCharacter
  avatarPreset CharacterAvatarPreset   @map("avatar_preset")

  currentXp Int @default(0) @map("current_xp")
  level   Int @default(1)
  health Int @default(100)
  dailyTaskXpCount Int @default(0) @map("daily_task_xp_count")
  checkinStreak Int @default(0) @map("checkin_streak")
  lastCheckinDayKey DateTime? @map("last_checkin_day_key") @db.Date

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model XpEvent {
  id        Int         @id @default(autoincrement())
  userId    Int         @map("user_id")
  type      XpEventType
  cardId    Int?        @map("card_id")
  dayKey    DateTime?   @map("day_key") @db.Date
  xpAmount  Int         @map("xp_amount")
  createdAt DateTime    @default(now()) @map("created_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card? @relation(fields: [cardId], references: [id], onDelete: SetNull)

  @@unique([userId, type, cardId])
  @@unique([userId, type, dayKey])
}

model HealthEvent {
  id        Int               @id @default(autoincrement())
  userId    Int               @map("user_id")
  dayKey    DateTime          @map("day_key") @db.Date
  delta     Int
  reason    HealthEventReason
  createdAt DateTime          @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayKey, reason])
}
