# ── База данных (PostgreSQL) ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/questflow
POSTGRES_DB=questflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# ── Аутентификация ───────────────────────────────────────────────────────
# Секрет для подписи JWT access/refresh токенов (минимум 32 символа для HS256)
JWT_SECRET=replace-with-strong-jwt-secret

# ── Приложение (URL) ───────────────────────────────────────────────────────
# Фронтенд и API — для CORS, OAuth redirect, ссылок в письмах
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:3000

# ── Redis (сессии, rate limiting) ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Google OAuth ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Почта (SendGrid) ───────────────────────────────────────────────────────
SENDGRID_API_KEY=your-sendgrid-api-key
MAIL_FROM=noreply@your-verified-domain-or-single-sender.com

# ── Геймификация ───────────────────────────────────────────────────────────
# IANA-часовой пояс сброса игровых суток (например Europe/Moscow или UTC)
GAME_DAY_TZ=UTC

# ── Web Push (браузерные уведомления) ─────────────────────────────────────
# Сгенерировать ключи: npm run vapid:generate
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@your-domain.com
