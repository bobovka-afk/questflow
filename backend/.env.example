DATABASE_URL=postgresql://postgres:password@localhost:5432/questflow
POSTGRES_DB=questflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

JWT_SECRET=replace-with-strong-jwt-secret

CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:3000

REDIS_HOST=localhost
REDIS_PORT=6379

# Google OAuth: console.cloud.google.com → OAuth-клиент (веб); redirect URI = SERVER_URL/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# SendGrid: app.sendgrid.com → ключ API; MAIL_FROM — верифицированный отправитель
SENDGRID_API_KEY=your-sendgrid-api-key
MAIL_FROM=noreply@your-verified-domain-or-single-sender.com

