# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/questflow
POSTGRES_DB=questflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# Authentication
# Secret for signing JWT access/refresh tokens (minimum 32 characters for HS256)
JWT_SECRET=replace-with-strong-jwt-secret

# Application URLs (CORS, OAuth redirects, email links)
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:3000

# Redis (sessions, rate limiting)
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
MAIL_FROM=noreply@your-verified-domain-or-single-sender.com

# Upload storage (local disk or Yandex/Selectel S3)
UPLOAD_STORAGE=local
# UPLOAD_STORAGE=s3
# S3_ENDPOINT=https://storage.yandexcloud.net
# S3_REGION=ru-central1
# S3_BUCKET=questflow-uploads
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_URL=https://storage.yandexcloud.net/questflow-uploads

# Gamification
# IANA timezone for game-day reset (e.g. Europe/Moscow or UTC)
GAME_DAY_TZ=UTC

# Web Push (browser notifications)
# Generate keys: npm run vapid:generate
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@your-domain.com
